programa {
  funcao inicio() {
    inteiro numero, acumulador=0

    para(inteiro i=1; i<=5; i++){
      escreva("INFORME N: ","\n")
      leia(numero)
      se(numero>=0 e numero <=100){
        acumulador++
    

      }
      }escreva("QUANTIDADES ENTRE 0 E 100: ","\n",acumulador)
      }


      
    }
    
  }
}
