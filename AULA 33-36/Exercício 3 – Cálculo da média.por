programa
{
    funcao inicio()
    {
        real n1, n2, media

        // INFORME O VALOR N1 E N2

        escreva("DIGITE N1: ")            
        leia(n1)

        escreva("DIGITE N2: ")
        leia(n2)

        media = (n1 + n2) / 2           // CALCULO DA MÉDIA

        escreva("Média: ", media)
    }
}