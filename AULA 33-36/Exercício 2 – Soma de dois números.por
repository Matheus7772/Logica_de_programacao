programa
{
    funcao inicio()
    {
        inteiro a, b, soma

                    // INFORME VALOR DE A E B

        escreva("Digite A: ")
        leia(a)

        escreva("Digite B: ")
        leia(b)
         
              //CALCULO DE A E B COM SOMA 

        soma = a + b

        escreva("Soma = ", soma)
    }
}