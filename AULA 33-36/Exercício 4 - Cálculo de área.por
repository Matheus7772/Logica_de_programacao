programa
{
    funcao inicio()
    {
        real largura, altura
        real area

                  // INFORME A LARGURA E A ALTURA DA ÁREA

        escreva("DIGITE A LARGURA: ")                         
        leia(largura)
        
        escreva("DIGITE A ALTURA: ")
        leia(altura)

                     // CALCULO DA ÁREA 
                      
        area = largura * altura

        escreva("Área: ", area)          
    }
}