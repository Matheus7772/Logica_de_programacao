programa {
  funcao inicio() {
    real nota  , frequencia 
    logico trabalhoEntreque = verdadeiro

    escreva("Digite a nota: ")
    leia(nota)

    escreva("Digite a frequencia: ")
    leia(frequencia)

    escreva("Aprovado: ", nota >=7 e frequencia >= 75 ou trabalhoEntreque == verdadeiro)
    
  }
}
