programa {
  funcao inicio() {
    cadeia disciplinas [5] = {"Português","história","ciências","ingles",""}

    escreva("INFORME A DISCIPLINA: ")
    leia(disciplinas[4])

    escreva(disciplinas[0],"\n")
    escreva(disciplinas[1],"\n")
    escreva(disciplinas[2],"\n")
    escreva(disciplinas[3],"\n")
    escreva(disciplinas[4],"\n")
    
  }
}
