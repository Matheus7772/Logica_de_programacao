programa {
  funcao inicio() {
    inteiro numeros[4]={10,5,2,8}
    inteiro calculo 
    calculo = numeros[0]+numeros[3]
    escreva("Soma do 0 e 3: ",calculo,"\n")

    calculo =numeros[1]*numeros[2]
    escreva("Multiplicação do 1 e 2: ",calculo,"\n")
    
    calculo =  numeros[2]-numeros[0]
    escreva("Diferença entre os valores: ",calculo) 
    
  }
}
