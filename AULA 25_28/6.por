programa {
  funcao inicio() {
    real _A
    real _B
    real aux 
    
  
    
    escreva("Valor variável A: ")
    leia(_A)

    escreva("Valor B: ")
    leia(_B)

    aux = _A
    _A = _B
    _B = aux

    escreva("Valor A: ", _A, "\n")

    escreva("Valor B: ", _B)



    
    



    
  }
}
