programa {
  funcao inicio() {
    real dollar 
    real reaL
    real cotacaoDollar = 5.24

    escreva("Cotação Atual do Dollar: ", cotacaoDollar,"\n")

    escreva("digite o valor dollar: ")
    leia(dollar)

    

    reaL = dollar*cotacaoDollar

    

    escreva("Saldo em U$$: ", dollar, "\n")

    escreva("Saldo em R$: ", reaL)  
  }
}
