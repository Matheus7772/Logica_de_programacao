programa {
  funcao inicio() {
    real altura = 1.75

    escreva("Altura: ", altura, "\n")

    escreva("Altura maior que 1.80? ",altura > 1.80, "\n")
    escreva("Altura menor que 2.00? ", altura <2.00,"\n")
    escreva("Altura maior ou igual 1.75? ", altura>=1.75,"\n")
    escreva("Altura diferente de 1.60? ", altura!=1.60,"\n")
    
  }
}
